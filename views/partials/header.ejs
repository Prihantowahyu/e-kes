<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#0d1b3e">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-title" content="Kesiswaan SMK">
  <link rel="manifest" href="/manifest.json">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>

<aside class="sidebar" id="sidebar">
  <div class="sidebar-brand">
    <div class="logo-icon">🏫</div>
    <div class="school-name">SMK Diponegoro Tumpang</div>
    <div class="system-name">Sistem Kesiswaan v3.0</div>
  </div>

  <nav class="sidebar-nav">
    <div class="nav-section-label">Utama</div>
    <a href="/dashboard" class="nav-link <%= typeof activePage!=='undefined'&&activePage==='dashboard'?'active':'' %>">
      <span class="nav-icon"><i class="fas fa-chart-line"></i></span> Dashboard
    </a>

    <div class="nav-section-label">Data Master</div>
    <a href="/siswa" class="nav-link <%= typeof activePage!=='undefined'&&activePage==='siswa'?'active':'' %>">
      <span class="nav-icon"><i class="fas fa-user-graduate"></i></span> Data Siswa
    </a>
    <a href="/petugas" class="nav-link <%= typeof activePage!=='undefined'&&activePage==='petugas'?'active':'' %>">
      <span class="nav-icon"><i class="fas fa-user-shield"></i></span> Petugas
    </a>
    <a href="/piket" class="nav-link <%= typeof activePage!=='undefined'&&activePage==='piket'?'active':'' %>">
      <span class="nav-icon"><i class="fas fa-calendar-week"></i></span> Jadwal Piket
    </a>

    <div class="nav-section-label">Kesiswaan</div>
    <a href="/pelanggaran" class="nav-link <%= typeof activePage!=='undefined'&&activePage==='pelanggaran'?'active':'' %>">
      <span class="nav-icon"><i class="fas fa-exclamation-triangle"></i></span> Pelanggaran
    </a>
    <a href="/sp" class="nav-link <%= typeof activePage!=='undefined'&&activePage==='sp'?'active':'' %>">
      <span class="nav-icon"><i class="fas fa-file-alt"></i></span> Surat Peringatan
    </a>
    <a href="/penyitaan" class="nav-link <%= typeof activePage!=='undefined'&&activePage==='penyitaan'?'active':'' %>">
      <span class="nav-icon"><i class="fas fa-box-open"></i></span> Penyitaan Barang
    </a>
    <a href="/kehadiran" class="nav-link <%= typeof activePage!=='undefined'&&activePage==='kehadiran'?'active':'' %>">
      <span class="nav-icon"><i class="fas fa-calendar-check"></i></span> Kehadiran
    </a>
    <a href="/kehadiran/input" class="nav-link <%= typeof activePage!=='undefined'&&activePage==='kehadiran-input'?'active':'' %>">
      <span class="nav-icon"><i class="fas fa-clipboard-list"></i></span> Input Absensi
    </a>
    <a href="/qr" class="nav-link <%= typeof activePage!=='undefined'&&activePage==='qr'?'active':'' %>">
      <span class="nav-icon"><i class="fas fa-qrcode"></i></span> QR Absensi
    </a>
    <a href="/rapor" class="nav-link <%= typeof activePage!=='undefined'&&activePage==='rapor'?'active':'' %>">
      <span class="nav-icon"><i class="fas fa-graduation-cap"></i></span> Rapor Perilaku
    </a>

    <div class="nav-section-label">Laporan</div>
    <a href="/laporan" class="nav-link <%= typeof activePage!=='undefined'&&activePage==='laporan'?'active':'' %>">
      <span class="nav-icon"><i class="fas fa-chart-bar"></i></span> Laporan & Statistik
    </a>
    <a href="/wali" class="nav-link <%= typeof activePage!=='undefined'&&activePage==='wali'?'active':'' %>">
      <span class="nav-icon"><i class="fas fa-chalkboard-teacher"></i></span> Dashboard Wali
    </a>

    <% if (user && user.role === 'admin') { %>
    <div class="nav-section-label">Administrasi</div>
    <a href="/users" class="nav-link <%= typeof activePage!=='undefined'&&activePage==='users'?'active':'' %>">
      <span class="nav-icon"><i class="fas fa-users-cog"></i></span> Manajemen User
    </a>
    <a href="/profil/log-aktivitas" class="nav-link <%= typeof activePage!=='undefined'&&activePage==='log'?'active':'' %>">
      <span class="nav-icon"><i class="fas fa-history"></i></span> Log Aktivitas
    </a>
    <% } %>
  </nav>

  <div class="sidebar-footer">
    <div class="user-card">
      <div class="user-avatar"><%= user ? user.nama.charAt(0).toUpperCase() : 'U' %></div>
      <div>
        <div class="user-name"><%= user ? user.nama : '' %></div>
        <div class="user-role"><%= user ? user.role.replace('_',' ') : '' %></div>
      </div>
    </div>
    <div style="display:flex;gap:6px;margin-bottom:8px">
      <a href="/profil" class="btn btn-secondary" style="flex:1;font-size:12px;padding:7px;justify-content:center">
        <i class="fas fa-user-cog"></i> Profil
      </a>
      <button onclick="toggleDark()" class="dark-toggle" title="Toggle Dark Mode" id="darkBtn">🌙</button>
    </div>
    <form action="/logout" method="POST">
      <button type="submit" class="logout-btn"><i class="fas fa-sign-out-alt"></i> Keluar</button>
    </form>
  </div>
</aside>

<div class="main-wrapper">
  <header class="topbar">
    <button class="btn btn-secondary btn-sm" id="sidebarToggle" style="display:none">
      <i class="fas fa-bars"></i>
    </button>
    <h1 class="page-title"><%= title %></h1>
    <div class="topbar-actions">
      <span class="text-sm text-muted"><i class="fas fa-clock"></i> <span id="clock"></span></span>
    </div>
  </header>

  <main class="main-content">
    <% if (success_msg && success_msg.length) { %>
      <div class="alert alert-success"><i class="fas fa-check-circle"></i> <%= success_msg[0] %></div>
    <% } %>
    <% if (error_msg && error_msg.length) { %>
      <div class="alert alert-danger"><i class="fas fa-times-circle"></i> <%= error_msg[0] %></div>
    <% } %>
    <% if (info_msg && info_msg.length) { %>
      <div class="alert alert-info"><i class="fas fa-info-circle"></i> <%= info_msg[0] %></div>
    <% } %>
