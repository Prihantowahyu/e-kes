<% activePage = 'siswa' %>
<%- include('../../partials/header') %>

<div style="max-width:700px;margin:0 auto">
  <div class="card">
    <div class="card-header">
      <i class="fas fa-<%= siswa ? 'edit' : 'plus-circle' %>" style="color:var(--blue)"></i>
      <span class="card-title"><%= siswa ? 'Edit Data Siswa' : 'Tambah Siswa Baru' %></span>
      <a href="/siswa" class="btn btn-secondary btn-sm"><i class="fas fa-arrow-left"></i> Kembali</a>
    </div>
    <div class="card-body">
      <form action="<%= action %>" method="<%= method %>" enctype="multipart/form-data">

        <div class="form-row form-row-2">
          <div class="form-group">
            <label class="form-label">NIS <span style="color:var(--accent)">*</span></label>
            <input type="text" name="nis" class="form-control mono"
              value="<%= siswa ? siswa.nis : '' %>"
              <%= siswa ? 'readonly style="background:var(--bg)"' : '' %>
              placeholder="Contoh: 2024001" required>
          </div>
          <div class="form-group">
            <label class="form-label">Nama Lengkap <span style="color:var(--accent)">*</span></label>
            <input type="text" name="nama" class="form-control"
              value="<%= siswa ? siswa.nama : '' %>" placeholder="Nama lengkap siswa" required>
          </div>
        </div>

        <div class="form-row form-row-2">
          <div class="form-group">
            <label class="form-label">Kelas <span style="color:var(--accent)">*</span></label>
            <input type="text" name="kelas" class="form-control"
              value="<%= siswa ? siswa.kelas : '' %>" placeholder="Contoh: X TKJ 1" required>
          </div>
          <div class="form-group">
            <label class="form-label">Jenis Kelamin <span style="color:var(--accent)">*</span></label>
            <select name="jenis_kelamin" class="form-control" required>
              <option value="L" <%= siswa && siswa.jenis_kelamin==='L' ? 'selected':'' %>>Laki-laki</option>
              <option value="P" <%= siswa && siswa.jenis_kelamin==='P' ? 'selected':'' %>>Perempuan</option>
            </select>
          </div>
        </div>

        <div class="form-row form-row-2">
          <div class="form-group">
            <label class="form-label">Nama Wali</label>
            <input type="text" name="nama_wali" class="form-control"
              value="<%= siswa ? siswa.nama_wali||'' : '' %>" placeholder="Nama orang tua/wali">
          </div>
          <div class="form-group">
            <label class="form-label">No. HP Wali</label>
            <input type="text" name="no_wali" class="form-control mono"
              value="<%= siswa ? siswa.no_wali||'' : '' %>" placeholder="Contoh: 081234567890">
          </div>
        </div>

        <div class="form-group">
          <label class="form-label">Alamat</label>
          <textarea name="alamat" class="form-control" rows="2" placeholder="Alamat lengkap"><%= siswa ? siswa.alamat||'' : '' %></textarea>
        </div>

        <% if (siswa) { %>
        <div class="form-group">
          <label class="form-label">Status</label>
          <select name="status" class="form-control">
            <option value="Aktif"      <%= siswa.status==='Aktif'?'selected':'' %>>Aktif</option>
            <option value="Non-Aktif"  <%= siswa.status==='Non-Aktif'?'selected':'' %>>Non-Aktif</option>
            <option value="Lulus"      <%= siswa.status==='Lulus'?'selected':'' %>>Lulus</option>
            <option value="Pindah"     <%= siswa.status==='Pindah'?'selected':'' %>>Pindah</option>
          </select>
        </div>
        <% } %>

        <div class="form-group">
          <label class="form-label">Foto Siswa</label>
          <input type="file" name="foto" class="form-control" accept="image/*">
          <% if (siswa && siswa.foto) { %>
            <div style="margin-top:8px">
              <img src="/uploads/<%= siswa.foto %>" style="height:60px;border-radius:8px;border:2px solid var(--border)">
            </div>
          <% } %>
        </div>

        <div style="display:flex;gap:8px;justify-content:flex-end;margin-top:8px">
          <a href="/siswa" class="btn btn-secondary"><i class="fas fa-times"></i> Batal</a>
          <button type="submit" class="btn btn-primary">
            <i class="fas fa-save"></i> <%= siswa ? 'Simpan Perubahan' : 'Tambah Siswa' %>
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('../../partials/footer') %>
