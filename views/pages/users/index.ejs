<% activePage = 'users' %>
<%- include('../../partials/header') %>

<div style="display:grid;grid-template-columns:1fr 340px;gap:20px;align-items:start">
  <div class="card">
    <div class="card-header">
      <i class="fas fa-users-cog" style="color:var(--blue)"></i>
      <span class="card-title">Daftar User (<%= users.length %>)</span>
    </div>
    <div class="table-wrapper">
      <table>
        <thead><tr><th>#</th><th>Username</th><th>Nama</th><th>Role</th><th>Kelas</th><th>Status</th><th>Aksi</th></tr></thead>
        <tbody>
          <% users.forEach((u, i) => { %>
          <tr>
            <td class="text-muted text-sm"><%= i+1 %></td>
            <td class="mono"><%= u.username %></td>
            <td><strong><%= u.nama %></strong></td>
            <td>
              <% const roleBadge={admin:'danger',tatib:'warning',wali_kelas:'info',petugas:'gray'} %>
              <span class="badge badge-<%= roleBadge[u.role]||'gray' %>"><%= u.role.replace('_',' ') %></span>
            </td>
            <td><%= u.kelas||'-' %></td>
            <td><span class="badge <%= u.aktif=='1'||u.aktif==1?'badge-success':'badge-gray' %>"><%= u.aktif=='1'||u.aktif==1?'Aktif':'Non-Aktif' %></span></td>
            <td>
              <div style="display:flex;gap:4px">
                <button class="btn btn-warning btn-xs" onclick="openEditUser(<%= JSON.stringify(u) %>)"><i class="fas fa-edit"></i></button>
                <% if (u.id != user.id) { %>
                <form action="/users/<%= u.id %>?_method=DELETE" method="POST" id="delu-<%= u.id %>">
                  <button type="button" class="btn btn-danger btn-xs" onclick="confirmDelete('delu-<%= u.id %>','Hapus user <%= u.nama %>?')"><i class="fas fa-trash"></i></button>
                </form>
                <% } %>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Form Tambah User -->
  <div class="card">
    <div class="card-header"><i class="fas fa-user-plus" style="color:var(--green)"></i><span class="card-title">Tambah User</span></div>
    <div class="card-body">
      <form action="/users" method="POST">
        <div class="form-group">
          <label class="form-label">Username</label>
          <input type="text" name="username" class="form-control mono" placeholder="username" required>
        </div>
        <div class="form-group">
          <label class="form-label">Password</label>
          <input type="password" name="password" class="form-control" placeholder="Min. 6 karakter" required minlength="6">
        </div>
        <div class="form-group">
          <label class="form-label">Nama Lengkap</label>
          <input type="text" name="nama" class="form-control" placeholder="Nama user" required>
        </div>
        <div class="form-group">
          <label class="form-label">Role</label>
          <select name="role" class="form-control">
            <option value="petugas">Petugas</option>
            <option value="wali_kelas">Wali Kelas</option>
            <option value="tatib">Tatib</option>
            <option value="admin">Admin</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Kelas (untuk Wali Kelas)</label>
          <input type="text" name="kelas" class="form-control" placeholder="Contoh: X TKJ 1">
        </div>
        <button type="submit" class="btn btn-primary w-100"><i class="fas fa-save"></i> Simpan User</button>
      </form>
    </div>
  </div>
</div>

<!-- Modal Edit User -->
<div class="modal-overlay" id="modalEditUser">
  <div class="modal">
    <div class="modal-header"><span class="modal-title"><i class="fas fa-edit"></i> Edit User</span><button class="modal-close" onclick="closeModal('modalEditUser')">✕</button></div>
    <form action="" method="POST" id="formEditUser">
      <div class="modal-body">
        <div class="form-group"><label class="form-label">Nama</label><input type="text" name="nama" id="editNama" class="form-control" required></div>
        <div class="form-group"><label class="form-label">Role</label>
          <select name="role" id="editRole" class="form-control">
            <option value="petugas">Petugas</option><option value="wali_kelas">Wali Kelas</option>
            <option value="tatib">Tatib</option><option value="admin">Admin</option>
          </select>
        </div>
        <div class="form-group"><label class="form-label">Kelas</label><input type="text" name="kelas" id="editKelas" class="form-control"></div>
        <div class="form-group"><label class="form-label">Password Baru (kosongkan jika tidak diubah)</label><input type="password" name="password" class="form-control" placeholder="Password baru..."></div>
        <div class="form-group"><label class="form-label">Status</label>
          <select name="aktif" id="editAktif" class="form-control">
            <option value="1">Aktif</option><option value="0">Non-Aktif</option>
          </select>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" onclick="closeModal('modalEditUser')">Batal</button>
        <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Simpan</button>
      </div>
    </form>
  </div>
</div>

<script>
function openEditUser(u) {
  document.getElementById('formEditUser').action = `/users/${u.id}?_method=PUT`;
  document.getElementById('editNama').value  = u.nama;
  document.getElementById('editKelas').value = u.kelas||'';
  document.getElementById('editAktif').value = u.aktif;
  const roleEl = document.getElementById('editRole');
  for (let o of roleEl.options) { if (o.value === u.role) { o.selected = true; break; } }
  openModal('modalEditUser');
}
</script>

<%- include('../../partials/footer') %>
